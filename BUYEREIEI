       target.Character.LeftUpperLeg.Transparency = 100
    end
    
    -- What players do we do this to?
    
    for i,v in pairs(game.Players:GetPlayers()) do --exisiting players
       if v ~= game:GetService("Players").LocalPlayer and v.Character then
